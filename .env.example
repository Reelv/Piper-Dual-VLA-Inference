# Piper SDK. Set this if piper_sdk is not installed in the active Python env.
# Example: /home/your-user/Lzr/Piper-Dual-Teleop/piper_sdk
PIPER_SDK_ROOT=

# RealSense serial numbers for the three-camera Piper dual-arm setup.
PIPER_CAM_HEAD_SERIAL=
PIPER_CAM_LEFT_WRIST_SERIAL=
PIPER_CAM_RIGHT_WRIST_SERIAL=

# Optional logging verbosity used by control_your_robot utilities.
INFO_LEVEL=INFO
