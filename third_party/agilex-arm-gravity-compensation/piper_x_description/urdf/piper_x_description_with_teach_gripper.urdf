  </joint>
  <link
    name="camera_support">
    <visual>
      <!--
        相机支架采用最开始的普通 Piper joint6 对齐方案：
        STL 由普通 Piper joint6 坐标系按毫米导出，因此挂到 piper_joint6_mount_frame 后只缩放到米。
      -->
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://meshes/camera_support.STL"
          scale="0.001 0.001 0.001" />
      </geometry>
      <material
