  <link
    name="piper_joint6_mount_frame">
    <!--
      这是无质量安装坐标系：现场确认 PiperX 的 joint6 需要转到 +1.57 rad，
      才与普通 Piper 上相机支架、Gemini305 和示教器的安装姿态对齐。
      因此从普通 Piper 迁移来的 payload 都挂在这个坐标系下，保持各自原始质量、质心和惯量定义不变。
    -->
  </link>
  <joint
    name="link6_to_piper_joint6_mount_frame"
    type="fixed">
    <origin
      xyz="0 0 0"
      rpy="0 0 1.5708" />
    <parent
      link="link6" />
    <child
      link="piper_joint6_mount_frame" />
  </joint>
  <link
    name="teach_base_visual">
    <!--
      teach_base_visual 仅用于现场示教器外观，不参与重补质量计算。
      它挂在 piper_joint6_mount_frame 下，因此不再单独叠加 B 方案旋转。
    -->
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://meshes/teach_base.STL" />
      </geometry>
