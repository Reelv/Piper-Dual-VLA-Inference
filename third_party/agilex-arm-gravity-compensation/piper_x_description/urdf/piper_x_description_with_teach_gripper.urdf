        ixz="0.000002725"
        iyy="0.000014347"
        iyz="0"
        izz="0.000018270" />
    </inertial>
  </link>
  <joint
    name="link6_to_camera_support"
    type="fixed">
    <!-- 支架直接对齐普通 Piper joint6 安装坐标系，不再单独叠加旋转。 -->
    <origin
      xyz="0 0 0"
      rpy="0 0 0" />
    <parent
      link="piper_joint6_mount_frame" />
    <child
      link="camera_support" />
  </joint>
